# Telegram Bot Token (get from @BotFather)
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Database URL
DATABASE_URL=sqlite+aiosqlite:///laundry.db

# Logging level
LOG_LEVEL=INFO

# Mini App URL (deployed frontend URL)
WEBAPP_URL=https://your-app.vercel.app

# Coin settings (optional, has defaults)
COINS_CLAIM=1
COINS_RELEASE=2
COINS_PING_COST=3
COINS_PING_RECEIVE=1
COINS_STARTING=10

# Reminder settings
REMINDER_BEFORE_MINUTES=5
